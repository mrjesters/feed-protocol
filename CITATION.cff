    family-names: Gul
    name-suffix: "IEng, MIET, IMechE, VCAT II, CAA"
version: "0.2.0"
date-released: "2026-06-20"
license: MIT
repository-code: "https://github.com/mrjesters/feed-protocol"
keywords:
  - llm
  - rag
  - grounding
  - protocol
  - citations
